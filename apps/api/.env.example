DATABASE_URL="mysql://root:password@localhost:3306/moona"
JWT_SECRET="change-me"
PORT=3000

# Xiaomi MiMo Token Plan uses an OpenAI-compatible endpoint.
# Replace the base URL with the endpoint shown on your token subscription page.
# Common examples:
# - Singapore: https://token-plan-sgp.xiaomimimo.com/v1
# - Amsterdam: https://token-plan-ams.xiaomimimo.com/v1
XIAOMI_MIMO_API_KEY=""
XIAOMI_MIMO_BASE_URL="https://token-plan-sgp.xiaomimimo.com/v1"
XIAOMI_MIMO_MODEL="xiaomi/mimo-v2-flash"

# Fallback generic OpenAI-compatible settings.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# WeChat Mini Program
WX_APPID=""
WX_APP_SECRET=""

# WeChat Pay V3 / Mini Program JSAPI payment
WX_PAY_MCH_ID=""
WX_PAY_CERT_SERIAL=""
# Use either raw PEM content with \n escapes, or base64 encoded PEM.
WX_PAY_PRIVATE_KEY=""
WX_PAY_PRIVATE_KEY_BASE64=""
WX_PAY_API_V3_KEY=""
# Recommended: WeChat Pay public key verification.
WX_PAY_PUBLIC_KEY_ID=""
WX_PAY_PUBLIC_KEY=""
WX_PAY_PUBLIC_KEY_BASE64=""
# Public HTTPS callback URL. If omitted, API_PUBLIC_BASE_URL + /api/payment/notify is used.
WX_PAY_NOTIFY_URL=""
API_PUBLIC_BASE_URL=""

# SMS (亿美软通)
SMS_APP_ID=""
SMS_SECRET_KEY=""
SMS_BASE_URL=""
SMS_TEMPLATE_ID=""
