generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  expense
  income
}

enum UserStatus {
  enabled
  disabled
}

model User {
  id           String        @id @default(cuid())
  phone        String?       @unique
  email        String?       @unique
  openid       String?       @unique
  wxSessionKey String?
  nickname     String        @default("")
  avatarUrl    String?       @db.Text // 可为 cloud:// fileID 或外链，需长于默认 VARCHAR
  passwordHash String?
  status       UserStatus    @default(enabled)
  lastLoginAt  DateTime?
  streakDays   Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions     Transaction[]
  tags             Tag[]
  aiLogs           AiLog[]
  aiReports        AiReport[]
  profile          UserProfile?
  budgets          Budget[]
  savingGoals      SavingGoal[]
  wealthSnapshots  WealthSnapshot[]
  goalProgresses   GoalProgress[]
  membership       Membership?
  orders           Order[]
  bookMembers      BookMember[]
  lifeSpaces       LifeSpace[]
  homeCardSettings HomeCardSetting[]
  userBadges       UserBadge[]
  userChallenges   UserChallenge[]
  memories         UserMemory[]
  identities       UserIdentity[]
  aiGreetingDailies AiGreetingDaily[]
  aiCorrections        AiCorrection[]
  announcementReads    UserAnnouncementRead[]

  /// 是否开启 AI米粒页「智能问候」（关闭后仅用本地默认文案）
  smartGreetingEnabled Boolean @default(true)
}

enum AiGreetingPeriod {
  midnight
  morning
  forenoon
  noon
  afternoon
  evening
  night
}

enum AiGreetingSource {
  ai
  default
}

model AiGreetingDaily {
  id         String           @id @default(cuid())
  userId     String
  date       DateTime         @db.Date
  period     AiGreetingPeriod
  title      String           @default("")
  subtitles  Json
  source     AiGreetingSource @default(default)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, period])
  @@index([userId, date])
}

enum IdentityProvider {
  wechat
  phone
}

model UserIdentity {
  id         String           @id @default(cuid())
  userId     String
  provider   IdentityProvider
  identifier String
  unionid    String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, identifier])
  @@index([userId])
}

model Category {
  id           String          @id @default(cuid())
  name         String
  icon         String
  color        String
  type         TransactionType
  sort         Int             @default(0)
  isSystem     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  transactions Transaction[]
  budgets      Budget[]

  @@unique([name, type])
}

model Transaction {
  id         String          @id @default(cuid())
  userId     String
  categoryId String
  bookId     String?
  lifeSpaceId String?
  type       TransactionType
  amount     Decimal         @db.Decimal(12, 2)
  occurredAt DateTime
  remark     String?
  voucherUrl String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category        @relation(fields: [categoryId], references: [id])
  book       SharedBook?     @relation(fields: [bookId], references: [id])
  lifeSpace  LifeSpace?      @relation(fields: [lifeSpaceId], references: [id])
  tags       TransactionTag[]

  @@index([userId, occurredAt])
  @@index([categoryId])
  @@index([bookId])
  @@index([lifeSpaceId])
}

model Tag {
  id           String           @id @default(cuid())
  userId       String
  name         String
  color        String           @default("#EEF2F6")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions TransactionTag[]

  @@unique([userId, name])
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model AiLog {
  id           String   @id @default(cuid())
  userId       String
  rawInput     String   @db.Text
  aiResponse   Json
  finalResult  Json?
  userModified Boolean  @default(false)
  confirmed    Boolean  @default(false)
  intent       String?
  status       String?  @default("success")
  model        String?
  durationMs   Int?
  errorMessage String?  @db.Text
  prompt       String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  corrections  AiCorrection[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum ReportType {
  daily
  monthly
}

model AiReport {
  id        String     @id @default(cuid())
  userId    String
  type      ReportType
  period    String
  content   Json
  summary   String     @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, period])
  @@index([userId, createdAt])
}

enum BudgetPeriod {
  weekly
  monthly
}

model Budget {
  id         String          @id @default(cuid())
  userId     String
  categoryId String?
  period     BudgetPeriod    @default(monthly)
  amount     Decimal         @db.Decimal(12, 2)
  month      String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category?       @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, month, period])
  @@index([userId, month])
}

model SavingGoal {
  id            String          @id @default(cuid())
  userId        String
  name          String
  targetAmount  Decimal         @db.Decimal(12, 2)
  currentAmount Decimal         @db.Decimal(12, 2) @default(0)
  deadline      DateTime?
  icon          String          @default("🎯")
  color         String          @default("#00d4c8")
  allocPercent  Int             @default(100)
  priority      Int             @default(0)
  completed     Boolean         @default(false)
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  progresses    GoalProgress[]

  @@index([userId])
}

model WealthSnapshot {
  id                String   @id @default(cuid())
  userId            String
  month             String
  income            Decimal  @db.Decimal(12, 2) @default(0)
  expense           Decimal  @db.Decimal(12, 2) @default(0)
  surplus           Decimal  @db.Decimal(12, 2) @default(0)
  cumulativeSurplus Decimal  @db.Decimal(12, 2) @default(0)
  wealthScore       Int      @default(0)
  adviceJson        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
}

model GoalProgress {
  id         String     @id @default(cuid())
  userId     String
  goalId     String
  month      String
  allocated  Decimal    @db.Decimal(12, 2) @default(0)
  cumulative Decimal    @db.Decimal(12, 2) @default(0)
  percent    Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal       SavingGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([userId, goalId, month])
  @@index([userId])
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  persona        String   @default("")
  traits         Json?
  lastAnalyzedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserMemoryType {
  finance_state
  preference
  goal
  warning
  profile
}

model UserMemory {
  id         String         @id @default(cuid())
  userId     String
  type       UserMemoryType
  key        String
  value      String         @db.Text
  confidence Float          @default(0.7)
  source     String         @default("chat")
  pinned     Boolean        @default(false)
  lastSeenAt DateTime       @default(now())
  expiresAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, type])
  @@index([userId, expiresAt])
}

// ===== 会员系统 =====

enum MemberLevel {
  free
  pro
  premium
}

enum OrderStatus {
  pending
  paid
  failed
  refunded
}

enum OrderType {
  subscription
  one_time
}

model Membership {
  id        String      @id @default(cuid())
  userId    String      @unique
  level     MemberLevel @default(free)
  expireAt  DateTime?
  autoRenew Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  type         OrderType   @default(subscription)
  amount       Decimal     @db.Decimal(12, 2)
  status       OrderStatus @default(pending)
  wxPayOrderId String?
  description  String?
  paidAt       DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([wxPayOrderId])
}

// ===== 共享账本 =====

enum BookType {
  daily
  love
  family
  work
  travel
  campus
  couple
}

enum BookRole {
  owner
  admin
  member
}

model SharedBook {
  id           String        @id @default(cuid())
  name         String
  type         BookType      @default(family)
  inviteCode   String        @unique
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  members      BookMember[]
  transactions Transaction[]
}

model LifeSpace {
  id          String        @id @default(cuid())
  userId      String
  type        BookType      @default(daily)
  name        String
  icon        String
  cover       String?
  color       String
  description String
  sort        Int           @default(0)
  isVisible   Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, type])
  @@index([userId, sort])
}

model HomeCardSetting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  sort      Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, sort])
}

model BookMember {
  id       String   @id @default(cuid())
  bookId   String
  userId   String
  role     BookRole @default(member)
  joinedAt DateTime @default(now())
  book     SharedBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookId, userId])
  @@index([userId])
}

// ===== 成长体系 =====

model Badge {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  icon        String
  description String
  condition   Json
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

enum ChallengeType {
  streak
  saving
  budget
}

model Challenge {
  id             String          @id @default(cuid())
  name           String
  description    String
  type           ChallengeType
  targetValue    Int
  duration       Int             @default(7)
  icon           String          @default("🏆")
  createdAt      DateTime        @default(now())
  userChallenges UserChallenge[]
}

model UserChallenge {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  startedAt   DateTime  @default(now())
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
}

// ===== 发现页 =====

enum ArticleCategory {
  tip
  knowledge
  challenge
}

model Article {
  id        String          @id @default(cuid())
  title     String
  summary   String
  content   String          @db.Text
  coverUrl  String?
  category  ArticleCategory @default(tip)
  published Boolean         @default(true)
  isPinned  Boolean         @default(false)
  sort      Int             @default(0)
  viewCount Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// ===== 运营管理后台 =====

enum AdminRole {
  super_admin
  admin
  operator
}

enum AdminUserStatus {
  enabled
  disabled
}

model AdminUser {
  id           String          @id @default(cuid())
  username     String          @unique
  passwordHash String
  nickname     String          @default("")
  role         AdminRole       @default(admin)
  status       AdminUserStatus @default(enabled)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  operationLogs AdminOperationLog[]
}

model AdminOperationLog {
  id         String    @id @default(cuid())
  adminId    String
  action     String
  module     String
  targetId   String?
  detailJson Json?
  ip         String?
  createdAt  DateTime  @default(now())
  admin      AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([module, createdAt])
}

enum AiCorrectionType {
  intent_error
  category_error
  amount_error
  space_error
  other
}

model AiCorrection {
  id                    String           @id @default(cuid())
  userId                String
  aiLogId               String?
  originalText          String           @db.Text
  aiIntent              String?
  aiResultJson          Json?
  correctedIntent       String?
  correctedResultJson   Json?
  correctionType        AiCorrectionType   @default(other)
  isAddedToPromptExamples Boolean        @default(false)
  remark                String?
  createdAt             DateTime         @default(now())
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiLog                 AiLog?           @relation(fields: [aiLogId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([correctionType, createdAt])
}

enum PromptExampleScene {
  bill_parse
  chat
  insight
  greeting
}

model PromptExample {
  id           String             @id @default(cuid())
  scene        PromptExampleScene @default(bill_parse)
  inputText    String             @db.Text
  expectedJson Json
  enabled      Boolean            @default(true)
  sort         Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

enum AnnouncementType {
  popup
  banner
  notice
}

enum AnnouncementPosition {
  global
  home
  ai
  discover
  profile
}

enum AnnouncementTarget {
  all
  free
  member
  specific
}

model Announcement {
  id             String               @id @default(cuid())
  title          String
  content        String               @db.Text
  type           AnnouncementType     @default(notice)
  position       AnnouncementPosition @default(global)
  target         AnnouncementTarget   @default(all)
  targetUserIds  Json?
  startAt        DateTime?
  endAt          DateTime?
  priority       Int                  @default(0)
  published      Boolean              @default(false)
  requireRead    Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  reads          UserAnnouncementRead[]
}

model UserAnnouncementRead {
  id             String       @id @default(cuid())
  userId         String
  announcementId String
  readAt         DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@index([announcementId])
}

model LifeSpaceTemplate {
  id          String   @id @default(cuid())
  type        BookType @unique
  name        String
  icon        String
  color       String
  description String   @db.Text
  aiTone      String   @db.Text
  enabled     Boolean  @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  group       String   @default("general")
  updatedAt   DateTime @updatedAt
}
